# EventMaps — exemple de configuration
# Dev local : copier en .env à la racine du projet (chargé automatiquement).
# Production : exporter ces variables via le process manager ou l'orchestrateur
#              (Docker -e, systemd EnvironmentFile, Kubernetes secrets, etc.).

# Environnement d'exécution : development | production
# En production, un EVENTMAPS_ALLOWED_ORIGINS resté au wildcard ('*')
# empêche le démarrage de l'application (RuntimeError).
EVENTMAPS_ENV=development

# Chemin vers la base de données SQLite
EVENTMAPS_DB_PATH=data/events.db

# Port d'écoute du serveur
EVENTMAPS_PORT=8000

# Niveau de log : DEBUG | INFO | WARNING | ERROR
EVENTMAPS_LOG_LEVEL=INFO

# Origines CORS autorisées (CSV ou tableau JSON)
# Valeur wildcard par défaut — À restreindre en production
EVENTMAPS_ALLOWED_ORIGINS=*
# Exemple production : EVENTMAPS_ALLOWED_ORIGINS=https://monapp.example.com

# Token Bearer pour protéger POST /scrape (laisser vide = endpoint public)
# EVENTMAPS_SCRAPE_TOKEN=changeme

# User-Agent HTTP des scrapers
EVENTMAPS_SCRAPE_USER_AGENT=EventMaps/1.0

# Timeout des jobs de scrape (heures)
EVENTMAPS_SCRAPE_TIMEOUT_HOURS=2

# Taux d'erreur max avant échec du job (0.0–1.0)
EVENTMAPS_SCRAPE_ERROR_THRESHOLD=0.5

# Timeout HTTP par requête scraper (secondes)
EVENTMAPS_SCRAPE_REQUEST_TIMEOUT_SECONDS=10

# Pages max par scraper
EVENTMAPS_SCRAPE_MAX_PAGES_TC=10
EVENTMAPS_SCRAPE_MAX_PAGES_HANABI=20
EVENTMAPS_SCRAPE_MAX_LISTING_PAGES_TOT=4

# Tentatives tenacity (retries) et backoff (secondes)
EVENTMAPS_SCRAPE_RETRY_ATTEMPTS=3
EVENTMAPS_SCRAPE_RETRY_WAIT_MIN=2
EVENTMAPS_SCRAPE_RETRY_WAIT_MAX=10

# Activer le log des timings HTTP des requêtes entrantes (false par défaut)
EVENTMAPS_REQUEST_LOGGING=false
