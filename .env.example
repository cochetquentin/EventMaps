# EventMaps — exemple de configuration
# Copier ce fichier en .env et adapter les valeurs

# Chemin vers la base de données SQLite
EVENTMAPS_DB_PATH=data/events.db

# Port d'écoute du serveur
EVENTMAPS_PORT=8000

# Niveau de log : DEBUG | INFO | WARNING | ERROR
EVENTMAPS_LOG_LEVEL=INFO

# Origines CORS autorisées (CSV ou tableau JSON)
# Valeur wildcard par défaut — À restreindre en production
EVENTMAPS_ALLOWED_ORIGINS=*
# Exemple production : EVENTMAPS_ALLOWED_ORIGINS=https://monapp.example.com

# Token Bearer pour protéger POST /scrape (laisser vide = endpoint public)
# EVENTMAPS_SCRAPE_TOKEN=changeme

# User-Agent HTTP des scrapers
EVENTMAPS_SCRAPE_USER_AGENT=EventMaps/1.0

# Timeout des jobs de scrape (heures)
EVENTMAPS_SCRAPE_TIMEOUT_HOURS=2

# Taux d'erreur max avant échec du job (0.0–1.0)
EVENTMAPS_SCRAPE_ERROR_THRESHOLD=0.5
